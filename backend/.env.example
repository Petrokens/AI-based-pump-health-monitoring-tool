# Copy to .env and fill in your values. Do not commit .env.

# MongoDB Atlas connection string (required for auth & admin APIs)
# Example: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?appName=Pump
# Get from: https://cloud.mongodb.com → Cluster → Connect → Driver
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST.mongodb.net/?appName=Pump

# Optional: Flask
# FLASK_ENV=development
# FLASK_DEBUG=1
